<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>音乐扒谱应用</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f5; display: flex; min-height: 100vh; }
        .sidebar { width: 220px; background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%); color: #fff; padding: 20px 0; display: flex; flex-direction: column; position: fixed; height: 100vh; }
        .sidebar-logo { padding: 0 20px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 20px; }
        .sidebar-logo h1 { font-size: 20px; color: #4ecdc4; }
        .sidebar-logo p { font-size: 12px; color: #888; margin-top: 5px; }
        .nav-item { padding: 15px 20px; cursor: pointer; display: flex; align-items: center; gap: 10px; transition: all 0.3s; color: #aaa; }
        .nav-item:hover { background: rgba(255,255,255,0.1); color: #fff; }
        .nav-item.active { background: rgba(78, 205, 196, 0.2); color: #4ecdc4; border-left: 3px solid #4ecdc4; }
        .nav-submenu { display: none; padding-left: 20px; }
        .nav-submenu.open { display: block; }
        .nav-item.sub { padding: 12px 20px; font-size: 14px; }
        .main-content { flex: 1; margin-left: 220px; padding: 30px; }
        .page { display: none; }
        .page.active { display: block; }
        .page-header { margin-bottom: 30px; }
        .page-header h2 { font-size: 28px; color: #333; }
        .page-header p { color: #666; margin-top: 5px; }
        .card { background: #fff; border-radius: 12px; padding: 24px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .card h3 { font-size: 18px; margin-bottom: 16px; color: #333; }
        .status { display: flex; align-items: center; gap: 10px; padding: 12px; background: #f8f9fa; border-radius: 8px; margin-bottom: 16px; }
        .status-dot { width: 12px; height: 12px; border-radius: 50%; background: #666; }
        .status-dot.active { background: #4ecdc4; }
        .status-dot.recording { background: #ff6b6b; animation: pulse 0.5s infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        .btn { padding: 10px 20px; border: none; border-radius: 8px; font-size: 14px; cursor: pointer; transition: all 0.3s; margin-right: 10px; margin-bottom: 10px; }
        .btn-primary { background: #4ecdc4; color: #fff; }
        .btn-primary:hover { background: #45b7aa; }
        .btn-danger { background: #ff6b6b; color: #fff; }
        .btn-secondary { background: #95a5a6; color: #fff; }
        .table { width: 100%; border-collapse: collapse; }
        .table th, .table td { padding: 12px; text-align: left; border-bottom: 1px solid #eee; }
        .table th { background: #f8f9fa; font-weight: 600; color: #666; }
        .table a { color: #4ecdc4; text-decoration: none; }
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; margin-bottom: 6px; color: #666; font-size: 14px; }
        .form-group input, .form-group select { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
        .artist-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; }
        .artist-card { background: #fff; border-radius: 12px; padding: 20px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .artist-avatar { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; margin: 0 auto 12px; background: #eee; }
        .artist-name { font-size: 16px; font-weight: bold; margin-bottom: 4px; }
        .artist-bio { font-size: 12px; color: #666; }
        .avatar-upload { display: flex; align-items: center; gap: 20px; margin-bottom: 16px; }
        .avatar-placeholder { width: 80px; height: 80px; border-radius: 50%; background: #ddd; display: flex; align-items: center; justify-content: center; color: #888; font-size: 24px; }
        .log { background: #1a1a2e; color: #0f0; padding: 12px; border-radius: 8px; font-family: monospace; font-size: 12px; max-height: 200px; overflow-y: auto; }
        .log-entry { margin-bottom: 4px; }
        .log-entry.error { color: #ff6b6b; }
        .log-entry.success { color: #4ecdc4; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-card { background: #fff; padding: 24px; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .stat-card .number { font-size: 36px; font-weight: bold; color: #4ecdc4; }
        .stat-card .label { color: #666; margin-top: 5px; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-logo"><h1>🎵 音乐扒谱</h1><p>Music Transcription</p></div>
        <div class="nav-item active" onclick="showPage('home')"><span>🏠</span><span>首页</span></div>
        <div class="nav-item" onclick="showPage('capture')"><span>🎙️</span><span>录音采集</span></div>
        <div class="nav-item" onclick="showPage('songs')"><span>🎵</span><span>歌曲库</span></div>
        <div class="nav-item" onclick="toggleArtistMenu()"><span>👤</span><span>歌手</span><span style="margin-left:auto;">▾</span></div>
        <div class="nav-submenu" id="artistSubmenu">
            <div class="nav-item sub" onclick="showPage('artists')"><span>📋 歌手列表</span></div>
            <div class="nav-item sub" onclick="showPage('add-artist')"><span>➕ 新增歌手</span></div>
        </div>
        <div class="nav-item" onclick="showPage('settings')"><span>⚙️</span><span>设置</span></div>
    </div>
    <div class="main-content">
        <div class="page active" id="page-home">
            <div class="page-header"><h2>欢迎使用音乐扒谱应用</h2><p>通过 WASAPI 录音采集音频，自动提取旋律和和弦</p></div>
            <div class="stats-grid">
                <div class="stat-card"><div class="number" id="stat-sessions">0</div><div class="label">采集会话数</div></div>
                <div class="stat-card"><div class="number" id="stat-songs">0</div><div class="label">歌曲总数</div></div>
                <div class="stat-card"><div class="number" id="stat-artists">0</div><div class="label">歌手数量</div></div>
            </div>
            <div class="card"><h3>快速开始</h3><p>1. 点击左侧「录音采集」开始采集音频</p><p>2. 采集完成后进行扒谱</p><p>3. 在「歌手」页面查看歌手，在「新增歌手」添加新歌手</p><p>4. 在「歌曲库」查看和管理您的作品</p><br><button class="btn btn-primary" onclick="showPage('capture')">开始采集</button></div>
        </div>
        <div class="page" id="page-capture">
            <div class="page-header"><h2>🎙️ 录音采集</h2><p>通过 WASAPI 采集系统音频</p></div>
            <div class="card"><h3>采集控制</h3><div class="status"><div class="status-dot" id="statusDot"></div><span id="statusText">等待操作</span></div><div><button class="btn btn-primary" onclick="startSession()">开始采集会话</button><button class="btn btn-danger" onclick="requestRecording()" id="btnStartRecording" disabled>请求开始录制</button><button class="btn btn-secondary" onclick="stopSession()">停止会话</button></div><div style="margin-top:16px"><strong>当前会话ID:</strong> <span id="currentSessionId">-</span></div></div>
            <div class="card"><h3>手动上传 WAV</h3><input type="file" id="wavFile" accept=".wav" style="margin-bottom:10px"><button class="btn btn-primary" onclick="uploadWavFile()">上传 WAV</button></div>
            <div class="card"><h3>历史记录 <button class="btn btn-secondary" onclick="loadRecordings()">刷新</button></h3><div id="recordingsList" style="margin-top:16px">点击「刷新」加载历史记录</div></div>
            <div class="card"><h3>扒谱识别</h3></div>
            <div class="card"><h3>创建歌曲</h3><div class="form-group"><label>歌曲名</label><input type="text" id="songTitle" placeholder="请输入歌曲名"></div><div class="form-group"><label>选择歌手</label><select id="songArtist"><option value="">-- 请选择歌手 --</option></select></div><div class="form-group"><label>歌曲类别</label><input type="text" id="songCategory" placeholder="如：流行、古典、摇滚"></div><button class="btn btn-primary" onclick="createSong()">创建歌曲记录</button></div>
            <div class="card"><h3>日志</h3><div class="log" id="log"></div></div>
        </div>
        <div class="page" id="page-songs">
            <div class="page-header"><h2>🎵 歌曲库</h2><p>管理您的歌曲和扒谱结果</p></div>
            <div class="card"><h3>歌曲列表 <button class="btn btn-secondary" onclick="loadSongs()">刷新</button></h3><div id="songsList" style="margin-top:16px">点击「刷新」加载歌曲</div></div>
        </div>
        <div class="page" id="page-song-detail">
            <div class="page-header"><h2>🎵 歌曲详情</h2><p>查看和编辑歌曲信息</p></div>
            <div class="card"><h3>基本信息</h3><div class="form-group"><label>歌曲名</label><input type="text" id="detailTitle"></div><div class="form-group"><label>选择歌手</label><select id="detailArtist"><option value="">-- 请选择歌手 --</option></select></div><div class="form-group"><label>歌曲类别</label><input type="text" id="detailCategory"></div><div class="form-group"><label>状态</label><select id="detailStatus"><option value="pending">待处理</option><option value="processing">处理中</option><option value="completed">已完成</option><option value="failed">失败</option></select></div><button class="btn btn-primary" onclick="saveSongDetail()">保存</button><button class="btn btn-danger" onclick="deleteSong()">删除</button>
                <button class="btn btn-primary" onclick="transcribeMelodyFromDetail()">提取单旋律</button>
                <button class="btn btn-primary" onclick="transcribeChordFromDetail()">提取和弦</button>
                <button class="btn btn-secondary" onclick="showPage('songs')">返回</button></div>
            <div class="card"><h3>文件信息</h3><div class="form-group"><label>音频文件</label><input type="text" id="detailAudioPath" readonly></div><div class="form-group"><label>旋律 MIDI</label><input type="text" id="detailMelodyPath" readonly></div><div class="form-group"><label>和弦 MIDI</label><input type="text" id="detailChordPath" readonly></div></div>
        </div>
        <div class="page" id="page-artists">
            <div class="page-header"><h2>👤 歌手列表</h2><p>查看已有歌手</p></div>
            <div class="card"><h3>歌手列表 <button class="btn btn-secondary" onclick="loadArtists()">刷新</button></h3><div id="artistsList" style="margin-top:16px">点击「刷新」加载歌手</div></div>
        </div>
        <div class="page" id="page-add-artist">
            <div class="page-header"><h2>➕ 新增歌手</h2><p>添加新的歌手信息</p></div>
            <div class="card"><h3>上传头像</h3><div class="avatar-upload"><div id="avatarPreview"><div class="avatar-placeholder">👤</div></div><div><input type="file" id="avatarFile" accept="image/*" onchange="previewAvatar()"><p style="color:#666;font-size:12px;margin-top:8px">支持 JPG、PNG 格式</p></div></div></div>
            <div class="card"><h3>歌手信息</h3><div class="form-group"><label>歌手名字 *</label><input type="text" id="artistName" placeholder="请输入歌手名字"></div><div class="form-group"><label>简介</label><input type="text" id="artistBio" placeholder="歌手简介"></div><button class="btn btn-primary" onclick="addArtist()">保存歌手</button></div>
        </div>
        <div class="page" id="page-settings">
            <div class="page-header"><h2>⚙️ 设置</h2><p>配置应用参数</p></div>
            <div class="card"><h3>数据库连接</h3><div class="form-group"><label>MySQL 主机</label><input type="text" id="dbHost" value="localhost"></div><div class="form-group"><label>MySQL 端口</label><input type="text" id="dbPort" value="3306"></div><div class="form-group"><label>数据库名称</label><input type="text" id="dbName" value="music_chrod_project"></div><div class="form-group"><label>用户名</label><input type="text" id="dbUser" value="aemeath"></div><div class="form-group"><label>密码</label><input type="password" id="dbPassword" value="paper_plane"></div><button class="btn btn-primary" onclick="testDbConnection()">测试连接</button></div>
        </div>
    </div>
    <script>
        const API_BASE = window.location.origin;
        let currentSessionId = null;
        let currentSongId = null;
        let uploadedAvatarPath = null;

        function toggleArtistMenu() { document.getElementById('artistSubmenu').classList.toggle('open'); }

        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            document.getElementById('page-' + pageId).classList.add('active');
            if (event && event.currentTarget) event.currentTarget.classList.add('active');
            if (pageId === 'home') loadStats();
            if (pageId === 'songs') loadSongs();
            if (pageId === 'artists') loadArtists();
            if (pageId === 'add-artist' || pageId === 'capture') loadArtistsForSelect();
            if (pageId === 'song-detail') loadSongDetail();
        }

        function viewSongDetail(id) { currentSongId = id; showPage('song-detail'); }

        function loadStats() {
            fetch(API_BASE + '/api/capture/list?limit=100').then(r => r.json()).then(data => { document.getElementById('stat-sessions').textContent = data.total || 0; });
            fetch(API_BASE + '/api/songs/list').then(r => r.json()).then(data => { document.getElementById('stat-songs').textContent = data.total || 0; });
            fetch(API_BASE + '/api/songs/artists/list').then(r => r.json()).then(data => { document.getElementById('stat-artists').textContent = data.total || 0; });
        }

        function log(message, type) {
            const logDiv = document.getElementById('log');
            const entry = document.createElement('div');
            entry.className = 'log-entry ' + (type || 'info');
            entry.textContent = '[' + new Date().toLocaleTimeString() + '] ' + message;
            logDiv.insertBefore(entry, logDiv.firstChild);
        }

        async function startSession() {
            try {
                log('创建采集会话...');
                const result = await fetch(API_BASE + '/api/capture/start', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ source: 'system_loopback' }) }).then(r => r.json());
                if (result.session_id) {
                    currentSessionId = result.session_id;
                    document.getElementById('currentSessionId').textContent = currentSessionId;
                    document.getElementById('btnStartRecording').disabled = false;
                    document.getElementById('statusDot').classList.add('active');
                    document.getElementById('statusText').textContent = '会话已创建，等待请求录制';
                    log('会话创建成功: ' + currentSessionId, 'success');
                }
            } catch (error) { log('创建会话失败: ' + error.message, 'error'); }
        }

        async function requestRecording() {
            if (!currentSessionId) { log('请先创建会话', 'error'); return; }
            try {
                log('请求开始录制...');
                const result = await fetch(API_BASE + '/api/capture/request-recording', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ session_id: currentSessionId }) }).then(r => r.json());
                if (result.status === 'recording_requested') {
                    document.getElementById('statusDot').classList.remove('active');
                    document.getElementById('statusDot').classList.add('recording');
                    document.getElementById('statusText').textContent = '正在录制...';
                    log('请求录制成功', 'success');
                }
            } catch (error) { log('请求录制失败: ' + error.message, 'error'); }
        }

        async function stopSession() {
            if (!currentSessionId) { log('没有活跃的会话', 'error'); return; }
            try {
                await fetch(API_BASE + '/api/capture/stop', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ session_id: currentSessionId }) });
                document.getElementById('statusDot').classList.remove('active', 'recording');
                document.getElementById('statusText').textContent = '会话已停止';
                document.getElementById('btnStartRecording').disabled = true;
                log('会话已停止', 'success');
                setTimeout(() => loadRecordings(), 1000);
            } catch (error) { log('停止会话失败: ' + error.message, 'error'); }
        }

        async function loadRecordings() {
            try {
                const result = await fetch(API_BASE + '/api/capture/list?limit=20').then(r => r.json());
                const listDiv = document.getElementById('recordingsList');
                if (result.sessions && result.sessions.length > 0) {
                    listDiv.innerHTML = '<table class="table"><thead><tr><th>会话ID</th><th>时长</th><th>状态</th><th>操作</th></tr></thead><tbody>' + result.sessions.map(s => '<tr><td>' + s.session_id + '</td><td>' + (s.duration_sec ? s.duration_sec.toFixed(1) + 's' : '-') + '</td><td>' + s.status + '</td><td><button class="btn btn-secondary" onclick="selectSession(\'' + s.session_id + '\')">选择</button></td></tr>').join('') + '</tbody></table>';
                } else { listDiv.innerHTML = '<p style="color:#aaa">暂无录音记录</p>'; }
            } catch (error) { log('加载列表失败: ' + error.message, 'error'); }
        }

        function selectSession(sessionId) { currentSessionId = sessionId; document.getElementById('currentSessionId').textContent = sessionId; log('已选择会话: ' + sessionId, 'success'); }

        async function uploadWavFile() {
            const file = document.getElementById('wavFile').files[0];
            if (!file) { log('请选择 WAV 文件', 'error'); return; }
            if (!currentSessionId) { log('请先创建或选择一个会话', 'error'); return; }
            const formData = new FormData();
            formData.append('session_id', currentSessionId);
            formData.append('audio_file', file);
            log('正在上传 WAV 文件...', 'info');
            fetch(API_BASE + '/api/capture/upload-file', { method: 'POST', body: formData }).then(r => r.json()).then(data => { if (data.ok) { log('✓ WAV 文件上传成功!', 'success'); loadRecordings(); } else { log('✗ 上传失败: ' + data.error, 'error'); } }).catch(e => log('✗ 上传失败: ' + e.message, 'error'));
        }



        async function createSong() {
            let audioPath = "";
            if (currentSessionId) {
                try {
                    const sess = await fetch(API_BASE + "/api/capture/detail/" + currentSessionId).then(r => r.json());
                    audioPath = sess.file_path || "";
                } catch(e) {}
            }
            const title = document.getElementById('songTitle').value;
            const artistId = document.getElementById('songArtist').value;
            const category = document.getElementById('songCategory').value;
            if (!title) { log('请输入歌曲名', 'error'); return; }
            try {
                log('创建歌曲...', 'info');
                const result = await fetch(API_BASE + '/api/songs/add', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ title: title, artist_id: artistId || null, category: category || null, source: 'wasapi_loopback', session_id: currentSessionId, audio_path: audioPath, status: 'pending' }) }).then(r => r.json());
                if (result.ok) { currentSongId = result.song_id; log('✓ 歌曲创建成功! ID: ' + result.song_id, 'success'); alert('歌曲创建成功! ID: ' + result.song_id); } else { log('创建失败: ' + result.error, 'error'); }
            } catch (error) { log('创建失败: ' + error.message, 'error'); }
        }

        async function loadSongs() {
            try {
                const result = await fetch(API_BASE + '/api/songs/list').then(r => r.json());
                const listDiv = document.getElementById('songsList');
                if (result.songs && result.songs.length > 0) {
                    listDiv.innerHTML = '<table class="table"><thead><tr><th>ID</th><th>歌名</th><th>类别</th><th>状态</th><th>创建时间</th></tr></thead><tbody>' + result.songs.map(s => '<tr><td>' + s.id + '</td><td><a href="#" onclick="viewSongDetail(' + s.id + ')">' + (s.title || '-') + '</a></td><td>' + (s.category || '-') + '</td><td>' + s.status + '</td><td>' + (s.created_at ? s.created_at.slice(0, 19) : '-') + '</td></tr>').join('') + '</tbody></table>';
                } else { listDiv.innerHTML = '<p style="color:#aaa">暂无歌曲</p>'; }
            } catch (error) { document.getElementById('songsList').innerHTML = '<p style="color:#aaa">加载失败</p>'; }
        }

        async function loadSongDetail() {
            if (!currentSongId) return;
            try {
                const result = await fetch(API_BASE + '/api/songs/' + currentSongId).then(r => r.json());
                if (result.error) { alert('加载失败'); return; }
                document.getElementById('detailTitle').value = result.title || '';
                document.getElementById('detailCategory').value = result.category || '';
                document.getElementById('detailStatus').value = result.status || 'pending';
                document.getElementById('detailAudioPath').value = result.audio_path || '';
                document.getElementById('detailMelodyPath').value = result.melody_path || '';
                document.getElementById('detailChordPath').value = result.chord_path || '';
                const artists = await fetch(API_BASE + '/api/songs/artists/list').then(r => r.json());
                document.getElementById('detailArtist').innerHTML = '<option value="">-- 请选择歌手 --</option>' + (artists.artists || []).map(a => '<option value="' + a.id + '">' + a.name + '</option>').join('');
                document.getElementById('detailArtist').value = result.artist_id || '';
            } catch (e) { console.error(e); }
        }

        async function transcribeMelodyFromDetail() {
            if (!currentSongId) { alert("请先选择一首歌曲"); return; }
            if (!confirm("确定要提取单旋律吗？")) return;
            try {
                log("开始提取单旋律...", "info");
                const result = await fetch(API_BASE + "/api/capture/transcribe", { method: "PUT", headers: {"Content-Type": "application/json"}, body: JSON.stringify({ song_id: currentSongId, mode: "melody" }) }).then(r => r.json());
                if (result.ok) { log("提取完成!", "success"); alert("提取完成!"); loadSongDetail(); } else { log("提取失败: " + result.error, "error"); }
            } catch (e) { log("提取失败: " + e.message, "error"); }
        }

        async function transcribeChordFromDetail() {
            if (!currentSongId) { alert("请先选择一首歌曲"); return; }
            if (!confirm("确定要提取和弦吗？")) return;
            try {
                log("开始提取和弦...", "info");
                const result = await fetch(API_BASE + "/api/capture/transcribe", { method: "PUT", headers: {"Content-Type": "application/json"}, body: JSON.stringify({ song_id: currentSongId, mode: "chord" }) }).then(r => r.json());
                if (result.ok) { log("提取完成!", "success"); alert("提取完成!"); loadSongDetail(); } else { log("提取失败: " + result.error, "error"); }
            } catch (e) { log("提取失败: " + e.message, "error"); }
        }

        async function deleteSong() {
            if (!currentSongId) return;
            if (!confirm("确定要删除这首歌曲吗？")) return;
            try {
                const result = await fetch(API_BASE + "/api/songs/" + currentSongId, { method: "DELETE" }).then(r => r.json());
                if (result.ok) { alert("删除成功"); showPage("songs"); } else { alert("删除失败: " + result.error); }
            } catch (e) { alert("删除失败"); }
        }

        async function saveSongDetail() {
            if (!currentSongId) return;
            const data = { title: document.getElementById('detailTitle').value, artist_id: document.getElementById('detailArtist').value || null, category: document.getElementById('detailCategory').value || null, status: document.getElementById('detailStatus').value };
            try {
                const result = await fetch(API_BASE + '/api/songs/' + currentSongId, { method: 'PUT', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(data) }).then(r => r.json());
                if (result.ok) { alert('保存成功'); loadSongs(); } else { alert('保存失败: ' + result.error); }
            } catch (e) { alert('保存失败'); }
        }

        async function loadArtists() {
            try {
                const result = await fetch(API_BASE + '/api/songs/artists/list').then(r => r.json());
                const listDiv = document.getElementById('artistsList');
                if (result.artists && result.artists.length > 0) {
                    listDiv.innerHTML = '<div class="artist-grid">' + result.artists.map(a => '<div class="artist-card">' + (a.avatar ? '<img src="' + a.avatar + '" class="artist-avatar">' : '<div class="avatar-placeholder">👤</div>') + '<div class="artist-name">' + a.name + '</div><div class="artist-bio">' + (a.bio || '暂无简介') + '</div></div>').join('') + '</div>';
                } else { listDiv.innerHTML = '<p style="color:#aaa">暂无歌手</p>'; }
            } catch (error) { document.getElementById('artistsList').innerHTML = '<p style="color:#aaa">加载失败</p>'; }
        }

        async function loadArtistsForSelect() {
            try {
                const result = await fetch(API_BASE + '/api/songs/artists/list').then(r => r.json());
                document.getElementById('songArtist').innerHTML = '<option value="">-- 请选择歌手 --</option>' + (result.artists || []).map(a => '<option value="' + a.id + '">' + a.name + '</option>').join('');
            } catch (error) {}
        }

        function previewAvatar() {
            const file = document.getElementById('avatarFile').files[0];
            const previewDiv = document.getElementById('avatarPreview');
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) { previewDiv.innerHTML = '<img src="' + e.target.result + '" style="width:80px;height:80px;border-radius:50%;object-fit:cover">'; };
                reader.readAsDataURL(file);
                const formData = new FormData();
                formData.append('file', file);
                fetch(API_BASE + '/api/upload/avatar', { method: 'POST', body: formData }).then(r => r.json()).then(data => { if (data.ok) { uploadedAvatarPath = data.path; log('头像上传成功', 'success'); } else { log('头像上传失败: ' + data.error, 'error'); } }).catch(e => log('头像上传失败: ' + e.message, 'error'));
            }
        }

        async function addArtist() {
            const name = document.getElementById('artistName').value;
            const bio = document.getElementById('artistBio').value;
            if (!name) { log('请输入歌手名字', 'error'); return; }
            try {
                log('添加歌手...', 'info');
                const result = await fetch(API_BASE + '/api/songs/artists/add', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ name: name, avatar: uploadedAvatarPath, bio: bio }) }).then(r => r.json());
                if (result.ok) { log('✓ 歌手添加成功! ID: ' + result.artist_id, 'success'); alert('歌手添加成功! ID: ' + result.artist_id); document.getElementById('artistName').value = ''; document.getElementById('artistBio').value = ''; document.getElementById('avatarPreview').innerHTML = '<div class="avatar-placeholder">👤</div>'; uploadedAvatarPath = null; } else { log('添加失败: ' + result.error, 'error'); }
            } catch (error) { log('添加失败: ' + error.message, 'error'); }
        }

        function testDbConnection() {
            const config = { host: document.getElementById('dbHost').value, port: document.getElementById('dbPort').value, database: document.getElementById('dbName').value, user: document.getElementById('dbUser').value, password: document.getElementById('dbPassword').value };
            log('测试数据库连接...', 'info');
            fetch(API_BASE + '/api/db/test', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(config) }).then(r => r.json()).then(data => { if (data.ok) log('✓ 数据库连接成功!', 'success'); else log('✗ 连接失败: ' + data.error, 'error'); }).catch(e => log('✗ 连接失败: ' + e.message, 'error'));
        }

        log('页面已加载');
    </script>
</body>
</html>