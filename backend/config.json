{
  "api": {
    "host": "0.0.0.0",
    "port": 5000,
    "debug": true
  },
  "spotify": {
    "auth_url": "https://accounts.spotify.com/api/token",
    "api_url": "https://api.spotify.com/v1",
    "search_limit": 50,
    "preview_timeout": 10
  },
  "audio": {
    "sample_rate": 22050,
    "hop_length": 512,
    "max_file_size": 536870912,
    "allowed_formats": [
      ".mp3",
      ".wav",
      ".flac",
      ".ogg",
      ".m4a",
      ".wma"
    ]
  },
  "transcription": {
    "melody": {
      "backend": "basic_pitch",
      "pitch_backend": "torchcrepe",
      "fmin": 65,
      "fmax": 1047,
      "hop_length": 512,
      "window_size": 7,
      "confidence_threshold": 0.5,
      "min_note_duration": 0.12,
      "midi_median_kernel_size": 7,
      "merge_gap_threshold": 0.10,
      "torchcrepe_model": "full",
      "torchcrepe_batch_size": 2048,
      "torchcrepe_viterbi": true,
      "default_tempo": 120,
      "preprocess_highpass_hz": 80,
      "preprocess_normalize": true,
      "use_pitch_channel": false,
      "onset_delta": 0.07,
      "onset_wait": 10,
      "onset_pre_max": 20,
      "onset_post_max": 20,
      "onset_pre_avg": 100,
      "onset_post_avg": 100,
      "segment_min_voiced_frames": 5,
      "pitch_onset_min_stable_frames": 6,
      "onset_merge_min_gap_frames": 5
    },
    "basic_pitch": {
      "onset_threshold": 0.4,
      "frame_threshold": 0.3,
      "minimum_note_length_ms": 80,
      "minimum_frequency": 65.0,
      "maximum_frequency": 1100.0,
      "melody_only": true,
      "midi_tempo": 120,
      "detect_tempo": true,
      "tempo_min": 60,
      "tempo_max": 200,
      "velocity_min": 50,
      "velocity_max": 120
    },
    "polyphonic": {
      "n_voices": 2,
      "hpss_margin": 4.0
    },
    "algorithm": {
      "chord": "librosa"
    },
    "vocal_separation": {
      "provider": "demucs",
      "fallback_order": ["spleeter", "librosa"],
      "demucs": {
        "model_name": "htdemucs",
        "two_stems": "vocals",
        "output_format": "wav",
        "device": "cpu",
        "jobs": 0,
        "segment": null,
        "shifts": 1,
        "overlap": 0.25
      }
    }
  },
  "paths": {
    "uploads": "./uploads",
    "outputs": "./outputs",
    "logs": "./logs"
  },
  "aliyunoss": {
    "endpoint": "oss-cn-guangzhou.aliyuncs.com",
    "bucket": "realllyka-music"
  },
  "database": {
    "enabled": true,
    "host": "192.168.5.129",
    "port": 3306,
    "database": "music_chrod_project",
    "user": "aemeath",
    "password": "paper_plane",
    "charset": "utf8mb4"
  }
}
